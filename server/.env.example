# Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fittracker?retryWrites=true&w=majority

# JWT Secret Key (use a strong random string)
JWT=your-super-secret-jwt-key-here

# Server Port (optional, defaults to 8080)
PORT=8080

# Google Gemini API Key (for AI Assistant feature)
GEMINI_API_KEY=your-gemini-api-key-here

# Client URL for CORS (optional, for production)
CLIENT_URL=https://your-frontend-url.com
